import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# --- Step 1: Generate Sample Sales Data ---
np.random.seed(42) # Added for consistent results
dates = pd.date_range(start='2023-01-01', periods=100, freq='D')
categories = ['Electronics', 'Clothing', 'Groceries', 'Furniture']

data = {
    'Date': np.random.choice(dates, 200),
    'Category': np.random.choice(categories, 200),
    'Sales_Amount': np.random.randint(100, 1000, 200),
    'Units_Sold': np.random.randint(1, 20, 200)
}

df = pd.DataFrame(data)

# --- Step 2: Data Pre-processing ---
df['Date'] = pd.to_datetime(df['Date'])

# Summary Statistics
print("--- Summary Statistics ---")
print(df.describe())

# --- Step 3: Visualizations ---

# 1. Sales Trend Over Time
plt.figure(figsize=(12, 6))
# Grouping data to show total daily sales
daily_sales = df.groupby('Date')['Sales_Amount'].sum().reset_index()
sns.lineplot(data=daily_sales, x='Date', y='Sales_Amount')
plt.title('Sales Trend Over Time')
plt.xlabel('Date')
plt.ylabel('Total Sales')
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()

# 2. Sales by Category (FIXED: Added hue mapping to avoid FutureWarning)
plt.figure(figsize=(10, 5))
category_sales = df.groupby('Category', as_index=False)['Sales_Amount'].sum()
sns.barplot(
    data=category_sales, 
    x='Category', 
    y='Sales_Amount', 
    hue='Category',   # Fixes the warning
    legend=False,     # Removes redundant legend
    palette='viridis'
)
plt.title('Total Sales by Category')
plt.xlabel('Category')
plt.ylabel('Sales Amount')
plt.show()

# 3. Distribution of Sales Amounts
plt.figure(figsize=(10, 5))
sns.histplot(df['Sales_Amount'], bins=20, kde=True, color='blue')
plt.title('Distribution of Sales Amounts')
plt.xlabel('Sales Amount')
plt.ylabel('Frequency')
plt.show()

# 4. Scatter Plot: Sales Amount vs. Units Sold
plt.figure(figsize=(10, 5))
sns.scatterplot(
    data=df, 
    x='Units_Sold', 
    y='Sales_Amount', 
    hue='Category', 
    palette='coolwarm'
)
plt.title('Sales Amount vs. Units Sold')
plt.xlabel('Units_Sold')
plt.ylabel('Sales Amount')
plt.legend(title='Category', bbox_to_anchor=(1.05, 1), loc='upper left')
plt.tight_layout()
plt.show()


