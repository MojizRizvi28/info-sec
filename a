import pandas as pd
import numpy as np
from sklearn.neighbors import KNeighborsClassifier
from sklearn.preprocessing import LabelEncoder
import matplotlib.pyplot as plt
# Step 1: Load movies dataset

movies = pd.read_csv("movies.csv")
movies

# Step 2: Encode Genre labels into numbers
le = LabelEncoder()
movies["Genre_Code"] = le.fit_transform(movies["Genre"])
# Features and target
X = movies[["Duration", "IMDB_Rating"]]
y = movies["Genre_Code"]
# Train KNN classifier (k=3)
knn = KNeighborsClassifier(n_neighbors=3)
knn.fit(X, y)

# Step 3: Add new movie Dhurandhar
dhurandhar_df = pd.DataFrame([[214, 8.6]], columns=["Duration", "IMDB_Rating"])
# Predict genre code for Dhurandhar
pred_code = knn.predict(dhurandhar_df)[0]
#Step 4: Predict the genre for the new movie Dhurandhar
# Convert predicted code back to text
pred_genre = le.inverse_transform([pred_code])[0]
print("Predicted Genre for Dhurandhar:", pred_genre)

# Step 5: Plot original data and Dhurandhar
colors = ["red", "green", "blue"]
plt.figure(figsize=(8,5))
for i, genre_name in enumerate(le.classes_):
    subset = movies[movies["Genre"] == genre_name]
    plt.scatter(subset["Duration"], subset["IMDB_Rating"],color=colors[i], label=genre_name, s=70)
plt.scatter(214, 8.6, color="black", marker="X", s=150, label="Dhurandhar")
plt.xlabel("Duration (minutes)")
plt.ylabel("IMDb Rating")
plt.title("KNN Classification of Movies")
plt.legend()
plt.grid(True)
plt.show()


