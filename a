import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

# Step 1: Create Data
diameter = np.array([8, 10, 12, 14, 16]).reshape(-1, 1)
price = np.array([10, 13, 16, 19, 22])

# Step 2: Create Linear Regression Model
model = LinearRegression()
model.fit(diameter, price)

# Step 3: Get Equation
intercept = model.intercept_
slope = model.coef_[0]
print("Regression Equation:")
print(f"Price = {intercept:.2f} + {slope:.2f} * Diameter")

# Step 4: Plot Graph
plt.figure(figsize=(8,6))
plt.scatter(diameter, price)
plt.plot(diameter, model.predict(diameter))
plt.title("Linear Regression - Pizza Data")
plt.xlabel("Diameter (inches)")
plt.ylabel("Price (dollars)")

# Step 5: Save Plot
plt.savefig("Linear_Regression_Plot.png")
plt.show()
print("Plot saved as Linear_Regression_Plot.png")


